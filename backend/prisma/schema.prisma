generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BillStatus {
  draft
  pending_approval
  approved
  scheduled
  paid
  rejected
  archived
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  ach
  wire
  check
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendor {
  id           String   @id @default(cuid())
  entityId     String   @default("company-x")
  name         String
  email        String
  taxId        String?
  paymentTerms Int      @default(30)
  defaultCurrency String @default("USD")
  category     String   @default("Software")
  bankAccount  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bills        Bill[]

  @@unique([entityId, name])
  @@index([entityId])
}

model Bill {
  id            String            @id @default(cuid())
  entityId      String            @default("company-x")
  invoiceNumber String
  vendorId      String
  vendor        Vendor            @relation(fields: [vendorId], references: [id])
  status        BillStatus        @default(draft)
  invoiceDate   DateTime
  dueDate       DateTime
  totalAmount   Float
  currency      String            @default("USD")
  notes         String?
  syncStatus    SyncStatus        @default(PENDING)
  /// Display id for QuickBooks-style tooltips (e.g. "8829")
  erpSyncRef    String?
  missingInfo   Boolean           @default(false)
  isArchived    Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lineItems     BillLineItem[]
  payments      Payment[]
  history       BillStatusHistory[]

  @@unique([entityId, invoiceNumber])
  @@index([entityId])
}

model BillLineItem {
  id          String @id @default(cuid())
  billId      String
  bill        Bill   @relation(fields: [billId], references: [id])
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  amount      Float
  category    String
}

model Payment {
  id          String        @id @default(cuid())
  billId      String
  bill        Bill          @relation(fields: [billId], references: [id])
  amount      Float
  paymentDate DateTime
  method      PaymentMethod @default(ach)
  reference   String?
  status      PaymentStatus  @default(SUCCESS)
  createdAt   DateTime      @default(now())
}

model BillStatusHistory {
  id        String     @id @default(cuid())
  billId    String
  bill      Bill       @relation(fields: [billId], references: [id])
  status    BillStatus
  comment   String?
  createdAt DateTime   @default(now())
}
